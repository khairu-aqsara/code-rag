# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_password_here

# Embedding model (Hugging Face public model, downloaded automatically on first use)
EMBED_MODEL=Alibaba-NLP/gte-modernbert-base
EMBED_DIM=768
# Model max is 8192; 2048 default balances CPU performance vs context coverage.
# Increase to 8192 on GPU or for very long code chunks.
EMBED_MAX_LENGTH=2048
EMBED_BATCH_SIZE=32

# Chunking
CODE_CHUNK_LINES=80
CODE_OVERLAP_LINES=20
DOC_CHUNK_SIZE=512

# Search
DEFAULT_TOP_K=10
MAX_TOP_K=20

# HNSW index parameters
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_RUNTIME=10

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Security: ingest endpoints restrict paths to this directory
BASE_PATH=/data

# Optional: customize Hugging Face cache location
# HF_HOME=/custom/path/.cache/huggingface

# Optional: prevent model downloads (only if models already cached)
# TRANSFORMERS_OFFLINE=1